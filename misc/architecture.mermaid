flowchart TD
    subgraph Client ["Frontend React"]
        UI["User Interface"]
        Voice["Voice "]
    end

    subgraph Backend ["Backend FastAPI"]
        API["API Router"]
        subgraph Services
            CS["Chat Service"]
            AS["Asset Service"]
            SS["Scene Service"]
        end
        subgraph Pipeline ["AI Pipeline"]
            RAG["RAG Engine"]
            LLM["LLM (OpenAI/Local)"]
        end
    end

    subgraph Data ["Storage"]
        SQL[(SQLite)]
        CDB[(ChromaDB)]
    end

    UI <-->|"HTTP JSON + Assets"| API
    API <-->|"Audio Streaming via WS"| Voice

    API --> AS
    API --> SS
    CS <--> RAG

    AS --> SQL
    SS --> SQL
    RAG --> CDB
    RAG --> LLM